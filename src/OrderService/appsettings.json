{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] ({CorrelationId}) {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=ordersdb;Username=postgres;Password=postgres",
    "RabbitMq": "amqp://guest:guest@localhost:5672"
  },
  "Consumer": {
    "ExchangeName": "orders.events",
    "QueueName": "order.created.queue",
    "RoutingKey": "order.created",
    "DeadLetterExchange": "orders.events.dlx",
    "DeadLetterQueue": "order.created.dlq",
    "DeadLetterRoutingKey": "order.created.dlq",
    "PrefetchCount": 20,
    "ConsumerName": "order-created-consumer"
  }
}
