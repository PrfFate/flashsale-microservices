{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Jwt": {
    "Issuer": "flashsale-gateway",
    "Audience": "flashsale-clients",
    "SigningKey": "change-this-super-secret-key-min-32-characters"
  },
  "ReverseProxy": {
    "Routes": {
      "campaign-list": {
        "ClusterId": "campaign-cluster",
        "Match": {
          "Path": "/api/campaigns/{**catch-all}"
        },
        "RateLimiterPolicy": "ip-policy"
      },
      "order-routes": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "ip-policy"
      },
      "inventory-routes": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "ip-policy"
      }
    },
    "Clusters": {
      "campaign-cluster": {
        "Destinations": {
          "campaign-service": {
            "Address": "http://localhost:8081"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-service": {
            "Address": "http://localhost:8082"
          }
        }
      }
    }
  }
}
